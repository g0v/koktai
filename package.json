{
  "name": "koktai",
  "private": true,
  "type": "module",
  "scripts": {
    "compile": "bun run scripts/compile-pug.ts",
    "sync": "bun run scripts/sync-static.ts",
    "precache": "bun run scripts/precache-pug.ts",
    "build:site": "bun run compile && bun run sync",
    "dev": "astro dev",
    "start": "bun run sync && astro dev",
    "build": "bun run sync && bun run precache && astro build && bun run scripts/check-built-html.ts",
    "preview": "astro preview",
    "gen:pug": "bun run scripts/gen-pug.ts",
    "diff:pug": "bun run scripts/diff-pug.ts",
    "parity:stage": "bun run scripts/parity-stage.ts",
    "parity:pipeline": "bun run diff:pug",
    "extract:readings": "bun run scripts/extract-readings.ts",
    "export:tei": "bun run scripts/export-tei.ts",
    "check": "tsgo --noEmit",
    "gen:maps-gif": "bun run scripts/font/maps-to-gif.ts",
    "gen:missing-gif": "bun run scripts/font/missings-to-gif.ts",
    "gen:missing-png": "bun run scripts/font/missings-to-png.ts"
  },
  "dependencies": {
    "astro": "^7.0.6",
    "iconv-lite": "^0.7.3",
    "pug": "^3.0.3",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/iconv-lite": "^0.0.1",
    "@types/pug": "^2.0.10",
    "@typescript/native-preview": "^7.0.0-dev.20260703.1",
    "fast-xml-parser": "^4"
  }
}