{
  "name": "koktai",
  "private": true,
  "type": "module",
  "scripts": {
    "compile": "bun run scripts/compile-pug.ts",
    "sync": "bun run scripts/sync-static.ts",
    "precache": "bun run scripts/precache-pug.ts",
    "measure:sections": "bun run scripts/measure-section-sizes.ts",
    "volume:stats": "bun run scripts/volume-stats.ts",
    "build:site": "bun run compile && bun run sync",
    "dev": "astro dev",
    "start": "bun run sync && astro dev",
    "section:snapshots": "bun run scripts/write-section-snapshots.ts",
    "build": "bun run sync && bun run precache && bun run section:snapshots && astro build && bun run scripts/check-built-html.ts",
    "preview": "astro preview",
    "gen:pug": "bun run scripts/gen-pug.ts",
    "diff:pug": "bun run scripts/diff-pug.ts",
    "parity:stage": "bun run scripts/parity-stage.ts",
    "parity:pipeline": "bun run diff:pug",
    "gen:font-json": "bun run scripts/font/gen-json.ts",
    "extract:readings": "bun run scripts/extract-readings.ts",
    "export:tei": "bun run scripts/export-tei.ts",
    "check": "tsgo --noEmit",
    "gen:maps-gif": "bun run scripts/font/maps-to-gif.ts",
    "gen:missing-gif": "bun run scripts/font/missings-to-gif.ts",
    "gen:missing-png": "bun run scripts/font/missings-to-png.ts",
    "check:search-dist": "bun run scripts/check-search-dist.ts",
    "font:build": "cargo build --release -p koktai-font",
    "regen:glyphs": "bun run scripts/font/regen-all-glyphs.ts",
    "gen:cp950-table": "bun run scripts/gen-cp950-table.ts"
  },
  "dependencies": {
    "astro": "^7.0.6",
    "fuse.js": "^7",
    "pug": "^3.0.3",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/pug": "^2.0.10",
    "@typescript/native-preview": "^7.0.0-dev.20260703.1",
    "iconv-lite": "^0.7.3"
  }
}