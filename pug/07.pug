        dd  вҶҗ<rt>г„ӢдёЁЛҠ</rt>гҖӮжҲ–дҪңпјҡеҗ¶/е“ӘгҖӮж–№иЁҖз”ЁгҖҗ<ruby>е“©<rt>&thinsp;г„ҢдёЁ&thinsp;</rt></ruby>гҖ‘гҖӮв‘ еҠ©з–‘е•ҸиӘһж°ЈгҖӮзӮәз”ҡ(/д»Җ)йәјпҪһгҖӮ<ruby>жҳҜ<rt>&thinsp;г„’дёЁЛ«&thinsp;</rt></ruby><ruby>жҢү<rt>&thinsp;г„ўЛӘ&thinsp;</rt></ruby><ruby>жҖҺ<rt>&thinsp;г„—г„ЁгҶ©ЛӢ&thinsp;</rt></ruby><ruby>е’§<rt>&thinsp;г„ҢгҶӨЛӘ&thinsp;</rt></ruby>пјҹ дҫӢпјҡдҪ е•ҸиӘ°пҪһгҖӮ<ruby>жұқ<rt>&thinsp;г„ҢдёЁЛӢ&thinsp;</rt></ruby><ruby>жҳҜ<rt>&thinsp;г„’дёЁЛ«&thinsp;</rt></ruby><ruby>еңЁ<rt>&thinsp;г„үгҶӨгҶ·&thinsp;</rt></ruby>(/<mark>&#xf9549;</mark>)<ruby>е•Ҹ<rt>&thinsp;г„ҮгҶӯЛ«&thinsp;</rt></ruby><ruby>з”ҡ<rt>&thinsp;г„’дёЁгҶ©ЛӢ&thinsp;</rt></ruby>(/е•Ҙпјҡдҝ—еӯ—)<ruby>йәј<rt>&thinsp;г„ҮдёЁгҶ·МҮ&thinsp;</rt></ruby><ruby>дәә<rt>&thinsp;г„Ңг„ӨЛҠ&thinsp;</rt></ruby><ruby>е’§<rt>&thinsp;г„ҢгҶӨЛӘ&thinsp;</rt></ruby>пјҹ дҪ еҲ°е“Әе…’еҺ»дәҶпҪһгҖӮ<ruby>жұқ<rt>&thinsp;г„ҢдёЁЛӢ&thinsp;</rt></ruby><ruby>й ӯ<rt>&thinsp;г„Ҡг„ ЛҠ&thinsp;</rt></ruby><ruby>жӢ„<rt>&thinsp;г„үг„ЁЛӢ&thinsp;</rt></ruby>(/<ruby>д№…<rt>&thinsp;г„Қг„ЁЛӢ&thinsp;</rt></ruby>)<ruby>д»”<rt>&thinsp;Лҷг„ҡ&thinsp;</rt></ruby><ruby>еҺ»<rt>&thinsp;г„ҺдёЁЛӘ&thinsp;</rt></ruby><ruby>йӮЈ<rt>&thinsp;г„үг„ңЛӢ&thinsp;</rt></ruby><ruby>дҪҚ<rt>&thinsp;г„ЁдёЁЛ«&thinsp;</rt></ruby><ruby>е’§<rt>&thinsp;г„ҢгҶӨЛӘ&thinsp;</rt></ruby>пјҹ жҖҺйәјиҫҰпҪһпјҹ(еҸ°)(<ruby>жҢү<rt>&thinsp;г„ўЛӘ&thinsp;</rt></ruby><ruby>зҲҫ<rt>&thinsp;г„ӢгҶӨ/г„ӢдёЁ&thinsp;</rt></ruby>)<ruby><mark>&#xffa49;</mark><rt>&thinsp;гҶ гҶӨгҶ·/гҶ г„ЁгҶӨгҶ·&thinsp;</rt></ruby><ruby>жҢү<rt>&thinsp;г„ўЛӘ&thinsp;</rt></ruby><ruby>жҖҺ<rt>&thinsp;г„—г„ЁгҶ©ЛӢ&thinsp;</rt></ruby><ruby>жЁЈ<rt>&thinsp;дёЁгҶ«Л«/дёЁгҶ§Л«&thinsp;</rt></ruby><ruby>иҫҰ<rt>&thinsp;г„…г„ўЛ«&thinsp;</rt></ruby>(/<ruby>еүө<rt>&thinsp;г„ҳгҶІЛӘ&thinsp;</rt></ruby>)<ruby>е’§<rt>&thinsp;г„ҢгҶӨЛӘ&thinsp;</rt></ruby>пјҹ (йҖҷжЁЈиӘӘ)е°ҚдёҚе°ҚпҪһпјҹ(еҸ°)<ruby>и‘—<rt>&thinsp;г„үдёЁг„ңгҶ·МҮ&thinsp;</rt></ruby><ruby>дёҚ<rt>&thinsp;гҶ¬Л«&thinsp;</rt></ruby>(/дј“)<ruby>и‘—<rt>&thinsp;г„үдёЁг„ңгҶ·МҮ&thinsp;</rt></ruby><ruby>е’§<rt>&thinsp;г„ҢгҶӨЛӘ&thinsp;</rt></ruby>пјҹ жҳҜиҙҠжҲҗйӮ„жҳҜеҸҚе°ҚпҪһпјҹиЁ»пјҡд»ҘдёҠеҸҘдёӯе·Іжңүз–‘е•Ҹи©һпјҢи©ўе•ҸеҸҘејҸгҖӮв‘Ўжә–д»Ји©ўе•Ҹи©һгҖӮеҸҘдёӯз„Ўи©ўе•Ҹи©һгҖӮ дҫӢпјҡеҫҢдҫҶпҪһпјҹ(еҸ°)<ruby>еҫҢ<rt>&thinsp;г„ Л«&thinsp;</rt></ruby><ruby>дҫҶ<rt>&thinsp;г„Ңг„һЛҠ&thinsp;</rt></ruby><ruby>е’§<rt>&thinsp;г„ҢгҶӨЛӘ&thinsp;</rt></ruby>пјҹ жҲ‘зҡ„еёҪеӯҗпҪһпјҹ(еҸ°)<ruby>жҠ‘<rt>&thinsp;г„ҡгҶ·МҮ&thinsp;</rt></ruby><ruby>жҲ‘<rt>&thinsp;гҶЈг„Ёг„ҡЛӢ&thinsp;</rt></ruby><ruby>дёҢ<rt>&thinsp;ЛҷгҶӨ&thinsp;</rt></ruby><ruby>еёҪ<rt>&thinsp;гҶ г„ңЛ«&thinsp;</rt></ruby><ruby>д»”<rt>&thinsp;Лҷг„ҡ&thinsp;</rt></ruby><ruby>е’§<rt>&thinsp;г„ҢгҶӨЛӘ&thinsp;</rt></ruby>пјҹ жҲ‘дҝЎпјҢдҪ пҪһпјҹ(еҸ°)<ruby>жҲ‘<rt>&thinsp;гҶЈг„Ёг„ҡЛӢ&thinsp;</rt></ruby><ruby>зӣё<rt>&thinsp;г„’дёЁгҶІ&thinsp;</rt></ruby><ruby>дҝЎ<rt>&thinsp;г„’дёЁг„ЈЛӘ&thinsp;</rt></ruby>пјҢ<ruby>жҠ‘<rt>&thinsp;г„ҡгҶ·МҮ&thinsp;</rt></ruby><ruby>жұқ<rt>&thinsp;г„ҢдёЁЛӢ&thinsp;</rt></ruby><ruby>е’§<rt>&thinsp;г„ҢгҶӨЛӘ&thinsp;</rt></ruby>пјҹ в‘ўеҠ©еҸҚе•ҸиӘһж°ЈгҖӮдҫӢпјҡжІ’жңүе№іең°пјҢе“ӘиЈЎжңғжңүй«ҳеұұпҪһпјҹ(еҸ°)<ruby>з„Ў<rt>&thinsp;гҶ г„ңЛҠ&thinsp;</rt></ruby><ruby>е№і<rt>&thinsp;г„…гҶіЛҠ/г„…гҶҘЛҠ&thinsp;</rt></ruby><ruby>ең°<rt>&thinsp;г„үгҶӨЛ«&thinsp;</rt></ruby><ruby><mark>&#xffa49;</mark><rt>&thinsp;гҶ гҶӨгҶ·/гҶ г„ЁгҶӨгҶ·&thinsp;</rt></ruby><ruby>йӮЈ<rt>&thinsp;г„Ӣг„ҡЛӢ&thinsp;</rt></ruby><ruby>жңғ<rt>&thinsp;г„ЁгҶӨЛ«/гҶӨЛ«&thinsp;</rt></ruby><ruby>жңү<rt>&thinsp;г„ЁЛ«&thinsp;</rt></ruby><ruby>жҮё<rt>&thinsp;г„Қг„Ёг„ўЛҠ&thinsp;</rt></ruby><ruby>еұұ<rt>&thinsp;г„ҷг„ЁгҶ©&thinsp;</rt></ruby><ruby>е’§<rt>&thinsp;г„ҢгҶӨЛӘ&thinsp;</rt></ruby>пјҹ в‘ЈеҠ©еј·иӘҝиӘһж°ЈпјҢеё¶иӘҮејөгҖӮ дҫӢпјҡд»ҠеӨ©еҸҜеҶ·пҪһгҖӮ<ruby>д»Ҡ<rt>&thinsp;г„ҚдёЁг„Ј&thinsp;</rt></ruby><ruby>д»”<rt>&thinsp;Лҷг„ҡ&thinsp;</rt></ruby><ruby>ж—Ҙ<rt>&thinsp;гҶўдёЁгҶөМҮ/г„ҢдёЁгҶөМҮ&thinsp;</rt></ruby><ruby>иӘ <rt>&thinsp;г„җдёЁгҶ©ЛҠ&thinsp;</rt></ruby><ruby>еҶ·<rt>&thinsp;г„ҢдёЁг„ҘЛӢ&thinsp;</rt></ruby><ruby>е–”<rt>&thinsp;гҶҰЛҠ&thinsp;</rt></ruby>пјҒ жҲ‘жІ’жңүз”ҡйәјпјҢдҪ еҖ‘жүҚиҫӣиӢҰпҪһгҖӮ<ruby>жҲ‘<rt>&thinsp;гҶЈг„Ёг„ҡЛӢ&thinsp;</rt></ruby><ruby>ж”Ҹ<rt>&thinsp;г„ҢгҶІЛӢ&thinsp;</rt></ruby><ruby>з„Ў<rt>&thinsp;гҶ г„ңЛҠ&thinsp;</rt></ruby><ruby>жҢү<rt>&thinsp;г„ўЛӘ&thinsp;</rt></ruby><ruby>жҖҺ<rt>&thinsp;г„—г„ЁгҶ©ЛӢ&thinsp;</rt></ruby>(<ruby>з„Ў<rt>&thinsp;гҶ г„ңЛҠ&thinsp;</rt></ruby><ruby>ијү<rt>&thinsp;г„үг„һЛ«&thinsp;</rt></ruby>(/<ruby>жҲҙ<rt>&thinsp;г„үг„һЛӘ&thinsp;</rt></ruby>)<ruby>дәӢ<rt>&thinsp;г„җдёЁЛӘ&thinsp;</rt></ruby>)пјҢ<ruby>жҒҒ<rt>&thinsp;г„ҢдёЁг„ЈЛӘ&thinsp;</rt></ruby><ruby>еӨ§<rt>&thinsp;г„үг„һЛ«&thinsp;</rt></ruby><ruby>е®¶<rt>&thinsp;г„ҚгҶӨ&thinsp;</rt></ruby><ruby>ијғ<rt>&thinsp;г„Һг„ҡгҶ·&thinsp;</rt></ruby><ruby>еӢһ<rt>&thinsp;г„Ңг„ңЛҠ&thinsp;</rt></ruby><ruby>иӢҰ<rt>&thinsp;г„ҺгҶҰЛӢ&thinsp;</rt></ruby><ruby>е–”<rt>&thinsp;гҶҰЛӘ&thinsp;</rt></ruby>пјҒ д»–йӮ„жңғдҪңи©©пҪһпјҒ(еҸ°)<ruby>дјҠ<rt>&thinsp;дёЁ&thinsp;</rt></ruby><ruby>зҢ¶<rt>&thinsp;дёЁг„ ЛӢ&thinsp;</rt></ruby><ruby>жңғ<rt>&thinsp;г„ЁгҶӨЛ«/гҶӨЛ«&thinsp;</rt></ruby><ruby>еҒҡ<rt>&thinsp;г„—г„ЁгҶӨЛӘ/г„—г„ңЛӘ&thinsp;</rt></ruby><ruby>и©©<rt>&thinsp;г„’дёЁ&thinsp;</rt></ruby><ruby>е’§<rt>&thinsp;г„ҢгҶӨЛӘ&thinsp;</rt></ruby>гҖӮ<ruby>дјҠ<rt>&thinsp;дёЁ&thinsp;</rt></ruby>(<ruby>дәҰ<rt>&thinsp;г„ҡгҶ·вҶ’дёЁг„ҡгҶ·МҮ&thinsp;</rt></ruby>)<ruby>жңғ<rt>&thinsp;г„ЁгҶӨЛ«/гҶӨЛ«&thinsp;</rt></ruby><ruby>еҒҡ<rt>&thinsp;г„—г„ЁгҶӨЛӘ/г„—г„ңЛӘ&thinsp;</rt></ruby><ruby>и©©<rt>&thinsp;г„’дёЁ&thinsp;</rt></ruby><ruby>е‘ў<rt>&thinsp;г„ӢгҶӨгҶ·МҮ&thinsp;</rt></ruby>(/<ruby>е–”<rt>&thinsp;гҶҰЛҠ&thinsp;</rt></ruby>)пјҒ в‘ӨиЎЁдәӢеҜҰпјҢеҠ©жұәе®ҡгҖҒзўәе®ҡе…јеј·иӘҝгҖӮдҫӢпјҡйӮ„жІ’дҫҶпҪһпјҒ(еҸ°)<ruby>зҢ¶<rt>&thinsp;дёЁг„ ЛӢ&thinsp;</rt></ruby><ruby>жңӘ<rt>&thinsp;гҶ гҶӨЛ«/гҶ г„ЁгҶӨЛ«&thinsp;</rt></ruby><ruby>дҫҶ<rt>&thinsp;г„Ңг„һЛҠ&thinsp;</rt></ruby><ruby>е’§<rt>&thinsp;г„ҢгҶӨЛӘ&thinsp;</rt></ruby>(/<ruby>е‘ў<rt>&thinsp;г„ӢгҶӨгҶ·&thinsp;</rt></ruby>/<ruby>йҒҺ<rt>&thinsp;г„Қг„ңгҶ·МҮ&thinsp;</rt></ruby>)гҖӮ жҲ‘дё”дёҚеҺ»пҪһпјҒ(еҸ°)<ruby><mark>&#xf9075;</mark><rt>&thinsp;г„ҸгҶӨ&thinsp;</rt></ruby><ruby>жҲ‘<rt>&thinsp;гҶЈг„Ёг„ҡЛӢ&thinsp;</rt></ruby><ruby>еҚі<rt>&thinsp;г„җдёЁг„ҡгҶ·&thinsp;</rt></ruby><ruby>жҳҜ<rt>&thinsp;г„’дёЁЛ«&thinsp;</rt></ruby><ruby>дёҚ<rt>&thinsp;гҶ¬Л«&thinsp;</rt></ruby>(/дј“)<ruby>еҺ»<rt>&thinsp;г„ҺдёЁЛӘ&thinsp;</rt></ruby><ruby>е’§<rt>&thinsp;г„ҢгҶӨЛӘ&thinsp;</rt></ruby>пјҒ ж—©и‘—пҪһпјҒ(еҸ°)<ruby>зҢ¶<rt>&thinsp;дёЁг„ ЛӢ&thinsp;</rt></ruby><ruby>ж—©<rt>&thinsp;г„—г„ҡЛӢ&thinsp;</rt></ruby><ruby>е’§<rt>&thinsp;г„ҢгҶӨЛӘ&thinsp;</rt></ruby>пјҒ жҳҜе•ҠпјҒе‘ҪеҘҪ<ruby>е‘ў<rt>&thinsp;Лҷг„Ӣг„ң&thinsp;</rt></ruby>(/еҗ¶)гҖӮ
