---
import type { StructuredReading } from "../../lib/site/structured-volume.ts";

interface Props {
  readings: StructuredReading[];
}

const { readings } = Astro.props;
---

{
  readings.map((reading) => (
    <span class="reading-chip">
      <span class="reading-zhuyin">{reading.zhuyin}</span>
      {(reading.register.length > 0 ||
        reading.geo.length > 0 ||
        reading.other.length > 0) && (
        <span class="reading-labels">
          {reading.register.map((v) => (
            <span class="usage-register">{v}</span>
          ))}
          {reading.geo.map((v) => (
            <span class="usage-geo">{v}</span>
          ))}
          {reading.other.map((v) => (
            <span class="usage-other">{v}</span>
          ))}
        </span>
      )}
    </span>
  ))
}