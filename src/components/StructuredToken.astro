---
import { legacyPlainText, renderLegacyText } from "../../lib/site/structured-render.ts";
import type { StructuredToken } from "../../lib/site/structured-volume.ts";
import ReadingChips from "./ReadingChips.astro";

interface Props {
  token: StructuredToken;
}

const { token } = Astro.props;

---

{
  token.kind === "syl" ? (
    <span class="token-syl">
      {token.readings.length > 0 ? (
        <ruby class="token-ruby zhuyin">
          <span class="token-han" set:html={renderLegacyText(token.han)} />
          {token.readings.map((reading) => (
            <rt>
              <span class="reading-zhuyin">{legacyPlainText(reading.zhuyin)}</span>
            </rt>
          ))}
        </ruby>
      ) : (
        <span class="token-han" set:html={renderLegacyText(token.han)} />
      )}
      {token.readings.map((reading) =>
        reading.register.length > 0 ||
        reading.geo.length > 0 ||
        reading.other.length > 0 ? (
          <span class="reading-labels">
            {reading.register.map((v) => (
              <span class="usage-register">{v}</span>
            ))}
            {reading.geo.map((v) => (
              <span class="usage-geo">{v}</span>
            ))}
            {reading.other.map((v) => (
              <span class="usage-other">{v}</span>
            ))}
          </span>
        ) : null,
      )}
    </span>
  ) : token.kind === "reading" ? (
    <span class="token-reading">
      <ReadingChips readings={token.readings} />
    </span>
  ) : token.kind === "prose" ? (
    <span class="token-prose" set:html={renderLegacyText(token.text)} />
  ) : (
    <span class="variant-chip">
      <span class="variant-body">
        (/
        {token.alternatives.map((alt, i) => (
          <>
            {i > 0 && <span class="variant-sep">/</span>}
            {alt.map((t) => (
              <Astro.self token={t} />
            ))}
          </>
        ))}
        )
      </span>
      {token.usages.register.map((v) => (
        <span class="usage-register">{v}</span>
      ))}
      {token.usages.geo.map((v) => (
        <span class="usage-geo">{v}</span>
      ))}
      {token.usages.other.map((v) => (
        <span class="usage-other">{v}</span>
      ))}
    </span>
  )
}