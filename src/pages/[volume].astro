---
import Dictionary from "../layouts/Dictionary.astro";
import {
  listPugPages,
  getVolumeData,
  scanPugVolume,
  chineseNumeral,
  wrapPe2Directives,
} from "../../lib/compile-pug.ts";
import { renderStructuredSection } from "../../lib/site/structured-render.ts";
import { getStructuredVolume } from "../../lib/site/structured-volume.ts";
import { getCorpus } from "../../lib/site/corpus.ts";

export function getStaticPaths() {
  return listPugPages(process.cwd()).map((base) => ({
    params: { volume: base },
    props: { base },
  }));
}

interface DocMeta {
  zh: string;
  file: string;
  kind: "prose" | "file";
  desc: string;
}

const APPENDIX: Record<string, DocMeta> = {
  preface1: {
    zh: "編輯緣起・凡例",
    file: "PREFACE1.DIC",
    kind: "prose",
    desc: "吳守禮自述編纂始末（代序），附全書凡例。",
  },
  phsource: {
    zh: "華語台語注音符號溯源",
    file: "PHSOURCE",
    kind: "prose",
    desc: "注音符號與臺灣方音符號的來歷考述。",
  },
  "ph-comp": {
    zh: "方音音標對照表",
    file: "PH-COMP.TXT",
    kind: "file",
    desc: "漢注、華臺、TLPA、國際音標、甘典、漢閩諸系統對照。",
  },
  mytaiin8: {
    zh: "綜合閩方言拼音總表",
    file: "MYTAIIN8",
    kind: "file",
    desc: "閩方言拼音系統總表。",
  },
  "dic-cont": {
    zh: "辭典內容說明",
    file: "DIC-CONT.TXT",
    kind: "file",
    desc: "原始檔案內容一覽。",
  },
};

const { base } = Astro.props;
const root = process.cwd();
const raw = getVolumeData(root, base);
const { sections, entries } = raw;
const isAppendix = !/^\d\d$/.test(base);
const isVolume = /^\d\d$/.test(base);
const html =
  isAppendix && APPENDIX[base] ? wrapPe2Directives(raw.html) : raw.html;
const structuredVolume = isVolume ? getStructuredVolume(root, base) : null;
const horizontalI = (s: string) => s.replaceAll("丨", "ㄧ");
const railSections =
  structuredVolume?.sections.map((sec, i) => {
    const syllable = horizontalI(sec.chapterZhuyin);
    const pugSec = sections.find(
      (s) => s.syllable === syllable || s.syllable === sec.chapterZhuyin,
    );
    return { id: `s-${i + 1}`, syllable, roman: pugSec?.roman ?? "" };
  }) ?? sections;
const volNo = isVolume ? Number(base) : 0;
const volName = isVolume ? `卷${chineseNumeral(volNo)}` : "";
const range =
  railSections.length > 0
    ? `${railSections[0]!.syllable}～${railSections[railSections.length - 1]!.syllable}`
    : "";
const pad = (n: number) => String(n).padStart(2, "0");
const prev = isVolume && volNo > 1 ? pad(volNo - 1) : null;
const next = isVolume && volNo < 26 ? pad(volNo + 1) : null;

const meta = APPENDIX[base];
const baseUrl = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const href = (path = "") => `${baseUrl}${path}`;
const linkCtx = isVolume
  ? { resolver: getCorpus(root).resolver, hrefBase: baseUrl }
  : undefined;
const title = isVolume
  ? `${volName} ${range}・國臺對照活用辭典`
  : `${meta?.zh ?? base}・國臺對照活用辭典`;
const description = isVolume
  ? `國臺對照活用辭典${volName}（${range}），共 ${(structuredVolume?.entryCount ?? entries).toLocaleString("en-US")} 條目。`
  : (meta?.desc ?? "國臺對照活用辭典附錄。");
---

<Dictionary title={title} description={description}>
  {
    isVolume ? (
      <>
      <div class="vol-layout">
        <aside class="rail" aria-label="音節索引">
          <p class="rail-tag">音節索引</p>
          <nav>
            <ul>
              {railSections.map((s) => (
                <li>
                  <a href={`#${s.id}`} data-spy={s.id}>
                    <span>{s.syllable}</span>
                    {s.roman && <span class="r">{s.roman}</span>}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        </aside>

        <article>
          <header class="vol-head">
            <p class="vol-eyebrow">辭典本文</p>
            <h1 class="vol-title">
              {volName}
              <span class="range">{range}</span>
            </h1>
            <p class="vol-meta">
              {railSections.length} 音節・{(structuredVolume?.entryCount ?? entries).toLocaleString("en-US")} 條目
            </p>
            <nav class="vol-nav" aria-label="卷次">
              {prev && <a href={href(`${prev}.html`)}>◀ 卷{chineseNumeral(volNo - 1)}</a>}
              <a href={href("#volumes")}>卷目</a>
              {next && <a href={href(`${next}.html`)}>卷{chineseNumeral(volNo + 1)} ▶</a>}
            </nav>
          </header>

          <div class="structured-doc">
            {structuredVolume!.sections.map((section, i) => {
              const rail = railSections[i]!;
              return (
                <Fragment
                  set:html={renderStructuredSection(section, {
                    id: rail.id,
                    syllable: rail.syllable,
                    roman: rail.roman ?? "",
                    note: "",
                  }, linkCtx)}
                />
              );
            })}
          </div>

          <nav class="vol-nav" aria-label="卷次（頁尾）">
            {prev && <a href={href(`${prev}.html`)}>◀ 卷{chineseNumeral(volNo - 1)}</a>}
            <a href={href("#volumes")}>卷目</a>
            {next && <a href={href(`${next}.html`)}>卷{chineseNumeral(volNo + 1)} ▶</a>}
          </nav>
        </article>
      </div>

      <details class="rail-sheet">
        <summary>音節索引</summary>
        <div class="sheet-panel">
          <ul>
            {railSections.map((s) => (
              <li>
                <a href={`#${s.id}`} data-spy={s.id}>
                  <span>{s.syllable}</span>
                  {s.roman && <span class="r">{s.roman}</span>}
                </a>
              </li>
            ))}
          </ul>
        </div>
      </details>
      </>
    ) : (
      <div class:list={["page", "doc-page", `doc-${meta?.kind ?? "prose"}`]}>
        <header class="vol-head">
          <p class="vol-eyebrow">附錄・原始檔</p>
          <h1 class="vol-title">{meta?.zh ?? base}</h1>
          <p class="vol-meta">{meta?.file}</p>
        </header>
        <p class="doc-note">
          本頁直接呈現 PE2 原始檔（Big-5 轉碼），保留當年的排版控制指令（.PO、.TL
          ……）與原稿斷行。
        </p>
        {meta?.kind === "file" ? (
          <>
            <p class="file-bar">{meta.file}</p>
            <div class="doc file-plate" set:html={html} />
          </>
        ) : (
          <div class="doc" set:html={html} />
        )}
      </div>
    )
  }
</Dictionary>

<script>
  // syllable scrollspy — highlights rail + sheet links (volume pages only)
  const spyLinks = document.querySelectorAll<HTMLAnchorElement>("a[data-spy]");
  if (spyLinks.length > 0) {
    const links = new Map<string, HTMLAnchorElement[]>();
    for (const a of spyLinks) {
      const id = a.dataset.spy ?? "";
      const list = links.get(id) ?? [];
      list.push(a);
      links.set(id, list);
    }

    let currentId = "";
    const setCurrent = (id: string) => {
      if (id === currentId) return;
      for (const a of links.get(currentId) ?? []) a.removeAttribute("aria-current");
      currentId = id;
      for (const a of links.get(id) ?? []) {
        a.setAttribute("aria-current", "true");
        if (a.closest(".rail")) a.scrollIntoView({ block: "nearest" });
      }
    };

    // content-visibility estimates settle AFTER a fragment jump, shifting the
    // target; re-align each frame until its position stabilises (bounded).
    const margin = 4; // keep in step with section.syl scroll-margin-top
    const settleTo = (id: string) => {
      const el = document.getElementById(id);
      if (!el) return;
      let frames = 0;
      let stable = 0;
      const step = () => {
        const top = el.getBoundingClientRect().top;
        if (Math.abs(top - margin) > 1) {
          el.scrollIntoView({ block: "start" });
          stable = 0;
        } else {
          stable++;
        }
        if (++frames < 24 && stable < 3) requestAnimationFrame(step);
        else setCurrent(id);
      };
      requestAnimationFrame(step);
    };
    const settleFromHash = () => {
      if (location.hash.startsWith("#s-")) settleTo(location.hash.slice(1));
    };
    for (const a of spyLinks) {
      a.addEventListener("click", () => settleTo(a.dataset.spy ?? ""));
    }
    window.addEventListener("hashchange", settleFromHash);
    settleFromHash();
    const heads = [...document.querySelectorAll<HTMLElement>("section.syl")];
    const visible = new Set<string>();
    const io = new IntersectionObserver(
      (recs) => {
        for (const r of recs) {
          if (r.isIntersecting) visible.add(r.target.id);
          else visible.delete(r.target.id);
        }
        for (const s of heads) {
          if (visible.has(s.id)) {
            setCurrent(s.id);
            break;
          }
        }
      },
      { rootMargin: "0px 0px -55% 0px" },
    );
    for (const s of heads) io.observe(s);

    // close the mobile sheet after choosing a syllable
    const sheet = document.querySelector<HTMLDetailsElement>(".rail-sheet");
    sheet?.addEventListener("click", (e) => {
      if ((e.target as HTMLElement).closest("a")) sheet.open = false;
    });
  }
</script>
