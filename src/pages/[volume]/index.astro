---
import Dictionary from "../../layouts/Dictionary.astro";
import { chineseNumeral } from "../../../lib/compile-pug.ts";
import { getStructuredVolume } from "../../../lib/site/structured-volume.ts";
import { buildRailSections } from "../../../lib/site/volume-rail.ts";
import { legacyPlainText } from "../../../lib/site/structured-render.ts";
import { volumeHubPath } from "../../../lib/site/volume-paths.ts";
import { VOLUME_IDS } from "../../../lib/dic/pipeline.ts";
import { volumeNav, volumeRangeText } from "../../../lib/site/volume-astro-shared.ts";

export function getStaticPaths() {
  return VOLUME_IDS.map((volume) => ({ params: { volume }, props: { volume } }));
}

const { volume } = Astro.props;
const root = process.cwd();
const volNo = Number(volume);
const structured = getStructuredVolume(root, volume);
const railSections = buildRailSections(root, volume);
const rangeText = volumeRangeText(railSections);
const baseUrl = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const href = (path = "") => `${baseUrl}${path}`;
const { prev, next, volName } = volumeNav(volNo, href);
const title = `${volName} ${rangeText}・國臺對照活用辭典`;
const description = `國臺對照活用辭典${volName}（${rangeText}），共 ${structured.entryCount.toLocaleString("en-US")} 條目。`;
---

<Dictionary title={title} description={description}>
  <div class="vol-layout vol-hub">
    <aside class="rail" aria-label="音節索引">
      <p class="rail-tag">音節索引</p>
      <nav>
        <ul>
          {
            railSections.map((s, i) => (
              <li>
                <a href={href(`${volume}/${i + 1}/index.html`)}>
                  <span>{legacyPlainText(s.syllable)}</span>
                  {s.roman && <span class="r">{legacyPlainText(s.roman)}</span>}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </aside>

    <article>
      <header class="vol-head">
        <p class="vol-eyebrow">辭典本文</p>
        <h1 class="vol-title">
          {volName}
          <span class="range">{rangeText}</span>
        </h1>
        <p class="vol-meta">
          {railSections.length} 音節・{structured.entryCount.toLocaleString("en-US")} 條目
        </p>
        <nav class="vol-nav" aria-label="卷次">
          {prev && <a href={href(volumeHubPath(prev))}>◀ 卷{chineseNumeral(volNo - 1)}</a>}
          <a href={href("#volumes")}>卷目</a>
          {next && <a href={href(volumeHubPath(next))}>卷{chineseNumeral(volNo + 1)} ▶</a>}
        </nav>
      </header>

      <ul class="vol-syl-list">
        {
          railSections.map((s, i) => (
            <li>
              <a class="vol-syl-card" href={href(`${volume}/${i + 1}/index.html`)}>
                <span class="vol-syl-zi">{legacyPlainText(s.syllable)}</span>
                {s.roman && <span class="vol-syl-rom">{legacyPlainText(s.roman)}</span>}
                <span class="vol-syl-count">
                  {s.entryCount} 詞・{s.sinogramCount} 字
                </span>
              </a>
            </li>
          ))
        }
      </ul>

      <nav class="vol-nav" aria-label="卷次（頁尾）">
        {prev && <a href={href(volumeHubPath(prev))}>◀ 卷{chineseNumeral(volNo - 1)}</a>}
        <a href={href("#volumes")}>卷目</a>
        {next && <a href={href(volumeHubPath(next))}>卷{chineseNumeral(volNo + 1)} ▶</a>}
      </nav>
    </article>
  </div>

  <details class="rail-sheet">
    <summary>音節索引</summary>
    <div class="sheet-panel">
      <ul>
        {
          railSections.map((s, i) => (
            <li>
              <a href={href(`${volume}/${i + 1}/index.html`)}>
                <span>{legacyPlainText(s.syllable)}</span>
                {s.roman && <span class="r">{legacyPlainText(s.roman)}</span>}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </details>
</Dictionary>

<script>
  const hash = location.hash;
  if (/^#s-\d+$/.test(hash)) {
    const n = hash.slice(3);
    const base =
      document.querySelector('meta[name="koktai-base"]')?.getAttribute("content") ?? "/";
    const vol = location.pathname.match(/\/(\d\d)\//)?.[1];
    if (vol) location.replace(`${base}${vol}/${n}/index.html`);
  }
</script>